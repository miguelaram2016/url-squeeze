# Environment Variables
# Copy this file to .env.local and fill in your values

# GitHub OAuth App (for sign-in)
# Create at: https://github.com/settings/applications/new
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Public base URL used for generated short links and QR links
# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Upstash Redis (for link storage)
# Sign up free at: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Optional: Affiliate IDs for monetization
# AFFILIATE_AMAZON=your-amazon-associate-tag
# AFFILIATE_TARGET=your-target-affiliate-id
# AFFILIATE_WALMART=your-walmart-affiliate-id
# AFFILIATE_BESTBUY=your-bestbuy-affiliate-id
# AFFILIATE_EBAY=your-ebay-affiliate-id
